@model BTVN5.Models.Book
@{
    ViewData["Title"] = "Chi tiết sách";
}

<div class="mb-3">
    <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
        &laquo; Trở về trang chủ
    </a>
</div>

<div class="row bg-white p-4 rounded shadow-sm">
    <div class="col-md-4">
        <div class="details-page-img">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.Title" />
            }
            else
            {
                <img src="/lib/bootstrap/dist/images/placeholder.jpg" alt="No image" />
            }
        </div>
        <div class="d-flex justify-content-between mt-3">
            <button class="btn btn-outline-danger w-50 me-2 btn-add-cart">
                <i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng
            </button>
            <button class="btn btn-danger w-50 btn-buy-now">
                Mua ngay
            </button>
        </div>
    </div>
    
    <div class="col-md-8 details-page-info">
        <h2 class="mb-3">@Model.Title</h2>
        
        <div class="row mb-3">
            <div class="col-md-6">
                <p>Nhà cung cấp: <strong>NXB Trẻ</strong></p>
                <p>Nhà xuất bản: <strong>NXB Trẻ</strong></p>
            </div>
            <div class="col-md-6">
                <p>Tác giả: <strong>@Model.Author</strong></p>
            </div>
        </div>
        
        <div class="text-warning mb-3">
            &#9733;&#9733;&#9733;&#9733;&#9733; <span class="text-muted">(79 đánh giá)</span>
        </div>
        
        <div class="d-flex align-items-center mb-4">
            <span class="price me-3">@Model.Price.ToString("N0") đ</span>
            @{
                var oldPrice = Model.Price * 1.25m; // Fake old price
            }
            <span class="old-price me-3">@oldPrice.ToString("N0") đ</span>
            <span class="discount">-20%</span>
        </div>
        
        <div class="row mb-3">
            <div class="col-md-3 text-muted">Thời gian giao hàng</div>
            <div class="col-md-9">Giao hàng đến <a href="#">Thay đổi</a></div>
        </div>
        
        <div class="row mb-4">
            <div class="col-md-3 text-muted">Chính sách đổi trả</div>
            <div class="col-md-9">Đổi trả sản phẩm trong 30 ngày <a href="#">Xem thêm</a></div>
        </div>
        
        <div class="row align-items-center mb-3">
            <div class="col-md-3 text-muted"><strong>Số lượng:</strong></div>
            <div class="col-md-9">
                <div class="input-group" style="width: 120px;">
                    <button class="btn btn-outline-secondary" type="button">-</button>
                    <input type="text" class="form-control text-center" value="1" />
                    <button class="btn btn-outline-secondary" type="button">+</button>
                </div>
            </div>
        </div>
        
        <div class="mt-4 border-top pt-3">
            <h5 class="text-uppercase font-weight-bold">Mô tả sản phẩm</h5>
            <p style="white-space: pre-line;">@Model.Description</p>
        </div>
    </div>
</div>
