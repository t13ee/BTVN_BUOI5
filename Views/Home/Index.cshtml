@model BTVN5.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Trang Chủ";
}

<div class="row">
    <!-- Sidebar: Chủ đề -->
    <div class="col-md-3">
        <h3 class="mb-3">Chủ đề</h3>
        <ul class="category-list">
            @foreach (var cat in Model.Categories)
            {
                <li>
                    <a href="#">@cat.Name (@cat.Count)</a>
                </li>
            }
        </ul>
    </div>

    <!-- Main Content: Sách -->
    <div class="col-md-9">
        <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-4">
            <h3 class="text-primary mb-0">Thêm mới</h3>
            <a asp-controller="Books" asp-action="Create" class="btn btn-primary btn-sm">Thêm sách mới</a>
        </div>

        <div class="row">
            @foreach (var item in Model.Books)
            {
                <div class="col-md-4">
                    <div class="book-card">
                        <div class="card-header-actions">
                            <span class="book-title text-truncate" title="@item.Title">@item.Title</span>
                            <a asp-controller="Books" asp-action="Edit" asp-route-id="@item.Id" class="text-primary text-decoration-none small">Edit</a>
                        </div>
                        <div class="book-info">
                            <p><strong>Tác giả:</strong> @item.Author</p>
                            <p><strong>Thể loại:</strong> @(item.Category?.Name ?? "N/A")</p>
                        </div>
                        <div class="book-img">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Title" />
                            }
                            else
                            {
                                <img src="/lib/bootstrap/dist/images/placeholder.jpg" alt="No image" />
                            }
                        </div>
                        <div class="book-actions">
                            <a asp-controller="Books" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">Chi tiết</a>
                            <a asp-controller="Books" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-success btn-sm text-white">Xóa</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
